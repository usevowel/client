{
  "name": "vowel-customer-voice-assistant",
  "version": "1.0.0",
  "description": "Customer-facing voice assistant for Shopify stores using Vowel AI",
  "type": "module",
  "main": "extensions/vowel-voice-widget/assets/vowel-voice-widget.min.js",
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build --watch",
    "dev": "vite build --watch",
    "deploy": "bun run build && shopify app deploy",
