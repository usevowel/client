  ],
  "author": "vowel.to",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.911.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/jest": "^29.5.8",
    "@types/node": "^22.10.4",
    "@types/react": "^19.0.6",
    "@types/react-dom": "^19.0.3",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react-swc": "^4.1.0",
    "eslint": "^8.55.0",
    "glob": "^11.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "tailwindcss": "^4.1.14",
    "terser": "^5.44.0",
    "typescript": "5.9.3",
